---
import ScrambleIn from '../components/scramble-in'
---

<style>
  header {
    display: grid;
    grid-template-columns: minmax(min(100%, 10ch), max-content) 1fr;
    align-items: center;
    gap: 1rem;
    margin-block-end: 4rem;
    padding-block-end: 1.5rem;
    border-block-end: 1px solid var(--clr-primary);
  }

  .ident {
    font-family: var(--fnt-serif);
    font-weight: 900;
    font-size: 2em;
    line-height: 1.1;
    text-wrap: balance;
    margin-block-start: 0;
    letter-spacing: clamp(-0.03em, calc((1em - 1rem) / -10), 0em);

    color: var(--clr-body);
    text-decoration: none;

    &:hover {
      color: var(--clr-primary);
    }
  }

  nav {
    display: grid;
    grid-template-columns: repeat(
      auto-fit,
      minmax(min(100%, 10ch), max-content)
    );
    justify-content: end;
    place-items: center;
    gap: 0.5rem;
    list-style: none;
  }
</style>

<header>
  <a href="/" class="ident"><ScrambleIn text="Alasdair Smith" client:load /></a>
  <nav aria-label="Main">
    <a href="/journal">Journal</a>
    <!-- <a href="/notes">Notes</a> -->
  </nav>
</header>
