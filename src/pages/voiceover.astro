---
import FullLayout from '../layouts/full.astro'

import data from '../voiceover.json'
---

<style>
  .container {
    display: grid;
    grid-template-columns: repeat(2, minmax(0, 1fr));
    gap: 2rem;
  }

  dl {
    display: grid;
    grid-template-columns: 1fr 2fr;
    gap: 0.75rem;
    font-size: 0.75rem;
    line-height: 1.75;
  }

  dd {
    display: flex;
    flex-wrap: wrap;
    align-items: baseline;
    gap: 0.25rem;
  }

  kbd {
    word-break: normal;
  }
</style>

<FullLayout title="VoiceOver Cheat Sheet">
  <div class="flow">
    <h1>VoiceOver Cheat Sheet</h1>
    <p>
      Cheat sheet for using VoiceOver on macOS with the default keybinding for
      the "VoiceOver key".
    </p>

    <div class="container">
      {
        data.sections.map((section) => (
          <article>
            <h2>{section.name}</h2>
            <dl>
              {section.tasks.map((task) => (
                <>
                  <dt>{task.description}</dt>
                  <dd>
                    {task.command.map((part, index, array) => (
                      <>
                        <kbd>{part}</kbd>
                        {index !== array.length - 1 ? '+' : null}
                      </>
                    ))}
                  </dd>
                </>
              ))}
            </dl>
          </article>
        ))
      }
    </div>
  </div>
</FullLayout>
